# Local development / local QA example.
# These test tokens are local-only placeholders. Never use them in staging or production.

NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_support_platform
REDIS_URL=redis://localhost:6379
API_PORT=4000

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Product-neutral default for new local envs.
# If you are using the current seeded demo data, you may temporarily set both slugs to kasta.
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo
WIDGET_DEFAULT_TENANT_SLUG=demo

AI_PROVIDER=deterministic
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000

ADMIN_API_PROTECTION_MODE=token
ADMIN_API_TOKEN=test-admin-token
ALLOW_UNPROTECTED_ADMIN_API_IN_DEV=false

API_INTERNAL_BASE_URL=http://localhost:4000/v1
ADMIN_WEB_ACCESS_TOKEN=test-web-token
ADMIN_WEB_SESSION_COOKIE_NAME=platform_admin_session
ADMIN_WEB_SESSION_SECRET=test-session-secret-for-local-qa
ADMIN_WEB_SESSION_TTL_SECONDS=43200
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/admin
CLERK_AFTER_SIGN_UP_URL=/admin
ADMIN_WEB_CLERK_SESSION_COOKIE_NAME=platform_clerk_session

KNOWLEDGE_IMPORT_USER_AGENT=PlatformKnowledgeImporter/0.1 knowledge-import
