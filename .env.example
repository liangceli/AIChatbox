# Runtime env reference. Copy one of the environment-specific examples below.
# Do not commit real secrets.

NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_support_platform
REDIS_URL=redis://localhost:6379
API_PORT=4000

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo
WIDGET_DEFAULT_TENANT_SLUG=demo

# Deterministic is the safe default. OpenAI must be enabled explicitly.
AI_PROVIDER=deterministic
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000

# Admin API protection is on by default. Use strong server-only values outside local QA.
ADMIN_API_PROTECTION_MODE=token
ADMIN_API_TOKEN=replace-with-strong-random-admin-api-token
# For Clerk alpha auth, set ADMIN_API_PROTECTION_MODE=clerk and configure:
# CLERK_JWT_KEY=<server-side-verification-public-key>
# CLERK_ISSUER=<expected-clerk-issuer>
# CLERK_AUTHORIZED_PARTIES=<admin-web-origin>
ALLOW_UNPROTECTED_ADMIN_API_IN_DEV=false

# Admin web server-side proxy/access settings. Never expose these through NEXT_PUBLIC_*.
API_INTERNAL_BASE_URL=http://localhost:4000/v1
ADMIN_WEB_ACCESS_TOKEN=replace-with-strong-random-admin-web-access-token
ADMIN_WEB_SESSION_COOKIE_NAME=platform_admin_session
ADMIN_WEB_SESSION_SECRET=replace-with-strong-random-session-secret
ADMIN_WEB_SESSION_TTL_SECONDS=43200
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/admin
CLERK_AFTER_SIGN_UP_URL=/admin
ADMIN_WEB_CLERK_SESSION_COOKIE_NAME=platform_clerk_session

KNOWLEDGE_IMPORT_USER_AGENT=PlatformKnowledgeImporter/0.1 knowledge-import
