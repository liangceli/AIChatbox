  },
  "dependencies": {
    "@platform/config": "workspace:*",
    "@platform/logging": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
