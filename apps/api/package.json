{
  "name": "@platform/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/main.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx scripts/provider-behavior.test.ts",
    "smoke:openai": "tsx scripts/openai-smoke.ts",
    "bootstrap:clerk-admin": "tsx scripts/bootstrap-clerk-admin.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@platform/ai-core": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/database": "workspace:*",
    "@platform/types": "workspace:*",
    "@platform/utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "openai": "^6.41.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
