{
  "name": "white-label-ai-support-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @platform/database prisma:generate",
    "db:migrate:dev": "pnpm --filter @platform/database prisma:migrate:dev",
    "db:seed": "pnpm --filter @platform/database prisma:seed",
    "db:studio": "pnpm --filter @platform/database prisma:studio"
  },
  "devDependencies": {
    "pnpm": "9.15.0",
    "turbo": "^2.0.14",
    "typescript": "^5.5.4"
  }
}
