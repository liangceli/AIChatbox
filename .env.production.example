# Production example.
# Store all secret values in the deployment secret manager, not in the repository.

NODE_ENV=production
DATABASE_URL=postgresql://user:password@prod-db.example.internal:5432/ai_support_platform
REDIS_URL=redis://prod-redis.example.internal:6379
API_PORT=4000

NEXT_PUBLIC_API_BASE_URL=https://api.example.com/v1
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo
WIDGET_DEFAULT_TENANT_SLUG=demo

# Keep deterministic until real OpenAI has passed staging smoke and manual QA.
AI_PROVIDER=deterministic
# AI_PROVIDER=openai
# OPENAI_API_KEY=<production-openai-key>
# OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000

ADMIN_API_PROTECTION_MODE=token
ADMIN_API_TOKEN=<production-strong-random-admin-api-token>
ALLOW_UNPROTECTED_ADMIN_API_IN_DEV=false

API_INTERNAL_BASE_URL=https://api.example.com/v1
ADMIN_WEB_ACCESS_TOKEN=<production-strong-random-admin-web-access-token>
ADMIN_WEB_SESSION_COOKIE_NAME=platform_admin_session
ADMIN_WEB_SESSION_SECRET=<production-strong-random-session-secret>
ADMIN_WEB_SESSION_TTL_SECONDS=43200

KNOWLEDGE_IMPORT_USER_AGENT=PlatformKnowledgeImporter/0.1 knowledge-import
