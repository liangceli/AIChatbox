# Staging / alpha example.
# Treat staging as production-like for secret handling. Do not use local QA tokens.

NODE_ENV=production
DATABASE_URL=postgresql://user:password@staging-db.example.internal:5432/ai_support_platform
REDIS_URL=redis://staging-redis.example.internal:6379
API_PORT=4000

NEXT_PUBLIC_API_BASE_URL=https://staging-api.example.com/v1
CORS_ALLOWED_ORIGINS=https://staging-admin.example.com,https://external-widget-test.example.com
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo
WIDGET_DEFAULT_TENANT_SLUG=demo

AI_PROVIDER=deterministic
# To test real OpenAI in staging, set all three values explicitly in the secret manager:
# AI_PROVIDER=openai
# OPENAI_API_KEY=<staging-openai-key>
# OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000

ADMIN_API_PROTECTION_MODE=clerk
CLERK_JWT_KEY=<staging-clerk-jwt-verification-public-key>
CLERK_ISSUER=<staging-clerk-issuer>
CLERK_AUTHORIZED_PARTIES=https://staging-admin.example.com
# Optional service/local fallback only; do not expose to browser:
# ADMIN_API_TOKEN=<staging-strong-random-admin-api-token>
ALLOW_UNPROTECTED_ADMIN_API_IN_DEV=false

API_INTERNAL_BASE_URL=https://staging-api.example.com/v1
# Legacy local fallback only:
# ADMIN_WEB_ACCESS_TOKEN=<staging-strong-random-admin-web-access-token>
ADMIN_WEB_SESSION_COOKIE_NAME=platform_admin_session
ADMIN_WEB_SESSION_SECRET=<staging-strong-random-session-secret>
ADMIN_WEB_SESSION_TTL_SECONDS=43200
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<staging-clerk-publishable-key>
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/admin
CLERK_AFTER_SIGN_UP_URL=/admin
ADMIN_WEB_CLERK_SESSION_COOKIE_NAME=platform_clerk_session

KNOWLEDGE_IMPORT_USER_AGENT=PlatformKnowledgeImporter/0.1 knowledge-import
