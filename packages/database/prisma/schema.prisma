generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  OPEN
  AWAITING_CUSTOMER
  AWAITING_AGENT
  PENDING_HUMAN
  ASSIGNED
  RESOLVED
  CLOSED
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  AGENT
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

enum ConversationChannel {
  WIDGET
  EMAIL
  PHONE
  API
}

enum MessageAuthor {
  CUSTOMER
  ASSISTANT
  AGENT
  SYSTEM
}

enum MessageType {
  TEXT
  SYSTEM_EVENT
  HANDOFF_EVENT
  INTERNAL_NOTE
}

enum KnowledgeDocumentStatus {
  DRAFT
  INDEXING
  READY
  FAILED
  ARCHIVED
  DELETED
}

enum KnowledgeChunkStatus {
  PROCESSING
  READY
  FAILED
  INACTIVE
  ARCHIVED
  DELETED
}

enum KnowledgeEmbeddingStatus {
  DISABLED
  PENDING
  READY
  FAILED
}

enum KnowledgeDocumentSourceType {
  FILE
  URL
  MANUAL
  INTEGRATION
}

model Tenant {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  status          TenantStatus     @default(ACTIVE)
  defaultLocale   String?
  branding        Json?
  metadata        Json?
  agentInvitationQuota Int              @default(5)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roles           Role[]
  customers       Customer[]
  conversations   Conversation[]
  messages        Message[]
  knowledgeBases  KnowledgeBase[]
  knowledgeDocs   KnowledgeDocument[]
  knowledgeChunks KnowledgeChunk[]
  productCatalog  ProductCatalog[]
  conversationStates ConversationState[]
  agentConfig     AgentConfig?
  invitations     TenantInvitation[]
  auditLogs       AuditLog[]
}

model User {
  id                    String          @id @default(cuid())
  email                 String          @unique
  clerkUserId           String?         @unique
  name                  String?
  isPlatformAdmin       Boolean         @default(false)
  metadata              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  roles                 Role[]
  assignedConversations Conversation[]  @relation("AssignedConversations")
  authoredMessages      Message[]       @relation("AuthoredMessages")
  sentInvitations       TenantInvitation[] @relation("InvitationSender")
  auditLogs             AuditLog[]
}

/// Tenant-scoped membership. Platform administration remains a separate User flag.
model Role {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  name      TenantRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, userId])
  @@index([tenantId, name])
  @@index([userId, status])
}

model TenantInvitation {
  id              String     @id @default(cuid())
  tenantId        String
  email           String
  role            TenantRole
  tokenHash       String     @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  invitedByUserId String
  createdAt       DateTime   @default(now())
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy       User       @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, email, expiresAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  tenantId       String?
  actorUserId    String?
  action         String
  resourceType   String
  resourceId     String?
  outcome        String
  requestId      String?
  metadata       Json?
  createdAt      DateTime @default(now())
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Customer {
  id             String         @id @default(cuid())
  tenantId       String
  visitorId      String?
  externalId     String?
  email          String?
  name           String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations  Conversation[]

  @@unique([id, tenantId])
  @@unique([tenantId, visitorId])
  @@unique([tenantId, externalId])
  @@index([tenantId, visitorId])
  @@index([tenantId, externalId])
  @@index([tenantId, email])
}

model Conversation {
  id                  String              @id @default(cuid())
  tenantId            String
  customerId          String
  assignedUserId      String?
  channel             ConversationChannel @default(WIDGET)
  status              ConversationStatus  @default(OPEN)
  subject             String?
  handoffRequestedAt  DateTime?
  handoffReason       String?
  lastMessageAt       DateTime?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer            Customer            @relation(fields: [customerId, tenantId], references: [id, tenantId], onDelete: Cascade)
  assignedUser        User?               @relation("AssignedConversations", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages            Message[]
  state               ConversationState?

  @@unique([id, tenantId])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, customerId])
}

model ProductCatalog {
  id                 String              @id @default(cuid())
  tenantId           String
  catalogKey         String
  productSeries      String?
  productName        String
  modelNumber        String?
  deviceType         String?
  aliases            Json?
  status             String              @default("ACTIVE")
  source             String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationStates ConversationState[]

  @@unique([id, tenantId])
  @@unique([tenantId, catalogKey])
  @@index([tenantId, productName])
  @@index([tenantId, modelNumber])
  @@index([tenantId, productSeries])
}

model ConversationState {
  conversationId         String          @id
  tenantId               String
  activeProductCatalogId String?
  activeProductContext   Json?
  activeConfidence       Float           @default(0)
  activeEntitySource     String?
  revision               Int             @default(1)
  stateJson              Json?
  expiresAt              DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  tenant                 Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation           Conversation    @relation(fields: [conversationId, tenantId], references: [id, tenantId], onDelete: Cascade)
  activeProductCatalog   ProductCatalog? @relation(fields: [activeProductCatalogId], references: [id], onDelete: SetNull)

  @@unique([conversationId, tenantId])
  @@index([tenantId, activeProductCatalogId])
  @@index([tenantId, updatedAt])
}

model Message {
  id              String         @id @default(cuid())
  tenantId        String
  conversationId  String
  authorUserId    String?
  authorType      MessageAuthor
  messageType     MessageType    @default(TEXT)
  clientMessageId String?
  content         String
  citations       Json?
  payload         Json?
  metadata        Json?
  createdAt       DateTime       @default(now())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation    Conversation   @relation(fields: [conversationId, tenantId], references: [id, tenantId], onDelete: Cascade)
  authorUser      User?          @relation("AuthoredMessages", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([id, tenantId])
  @@unique([tenantId, clientMessageId])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, authorUserId, createdAt])
  @@index([tenantId, messageType, createdAt])
}

model KnowledgeBase {
  id            String              @id @default(cuid())
  tenantId      String
  slug          String
  name          String
  description   String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents     KnowledgeDocument[]

  @@unique([id, tenantId])
  @@unique([tenantId, slug])
  @@index([tenantId, name])
}

model KnowledgeDocument {
  id                String                      @id @default(cuid())
  tenantId          String
  knowledgeBaseId   String
  title             String
  sourceType        KnowledgeDocumentSourceType
  sourceUri         String?
  content           String?
  checksum          String?
  storageKey        String?
  status            KnowledgeDocumentStatus    @default(DRAFT)
  chunkCount        Int                        @default(0)
  version           Int                        @default(1)
  processingError   String?
  metadata          Json?
  ingestedAt        DateTime?
  archivedAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeBase     KnowledgeBase              @relation(fields: [knowledgeBaseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  chunks            KnowledgeChunk[]

  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([knowledgeBaseId])
}

model KnowledgeChunk {
  id                   String              @id @default(cuid())
  tenantId             String
  knowledgeDocumentId  String
  version              Int                 @default(1)
  chunkIndex           Int
  content              String
  contentHash          String?
  tokenCount           Int?
  status               KnowledgeChunkStatus     @default(READY)
  embeddingStatus      KnowledgeEmbeddingStatus @default(DISABLED)
  sourceLocator        Json?
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeDocument    KnowledgeDocument   @relation(fields: [knowledgeDocumentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, knowledgeDocumentId, version, chunkIndex])
  @@index([tenantId, knowledgeDocumentId])
  @@index([tenantId, status])
}

model AgentConfig {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  displayName        String
  systemPrompt       String?
  welcomeMessage     String?
  fallbackMessage    String?
  handoffEnabled     Boolean   @default(true)
  escalationRules    Json?
  retrievalSettings  Json?
  widgetSettings     Json?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
}
