  <diagram id="rag-answer-clean" name="02 RAG与答案生成">
    <mxGraphModel dx="1501" dy="651" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="2050" math="0" shadow="0">
      <root>
        <mxCell id="r0" />
        <mxCell id="r1" parent="r0" />
        <mxCell id="r-title" parent="r1" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Haneco AI Pilot｜Conversation Understanding、Hybrid RAG 与答案生成" vertex="1">
          <mxGeometry height="50" width="1200" x="300" y="20" as="geometry" />
        </mxCell>
        <mxCell id="r-lane-a" parent="r1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="A. 对话理解与 Query Normalisation" vertex="1">
          <mxGeometry height="430" width="1680" x="60" y="100" as="geometry" />
        </mxCell>
        <mxCell id="r-input" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;fontStyle=1;" value="Customer Message + Conversation Context" vertex="1">
          <mxGeometry height="65" width="500" x="650" y="155" as="geometry" />
        </mxCell>
        <mxCell id="r-classify" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" value="ConversationContextService（更新）&lt;br&gt;问候｜社交｜感谢｜确认｜新问题｜追问｜澄清回复｜人工请求" vertex="1">
          <mxGeometry height="75" width="520" x="640" y="260" as="geometry" />
        </mxCell>
        <mxCell id="r-state" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#000000;fontSize=12;" value="读取状态&lt;br&gt;ConversationState → ProductCatalog → legacy fallback&lt;br&gt;pendingClarification + productContext" vertex="1">
          <mxGeometry height="90" width="390" x="130" y="260" as="geometry" />
        </mxCell>
        <mxCell id="r-routing-policy" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="新增：租户可配置路由策略&lt;br&gt;AgentConfig.metadata.conversationRouting&lt;br&gt;短语集合 + 各类型回复（非产品硬编码）" vertex="1">
          <mxGeometry height="75" width="400" x="120" y="155" as="geometry" />
        </mxCell>
        <mxCell id="r-conversation-decision" parent="r1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="社交 / 问候 / 感谢 / 确认？" vertex="1">
          <mxGeometry height="100" width="320" x="1240" y="245" as="geometry" />
        </mxCell>
        <mxCell id="r-conversation-reply" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" value="直接会话回复（新增）&lt;br&gt;AssistantReplyService&lt;br&gt;retrievalSkipped = true｜0 citations&lt;br&gt;保留 pendingClarification；回到第 1 页并发检查与落库" vertex="1">
          <mxGeometry height="100" width="360" x="1215" y="390" as="geometry" />
        </mxCell>
        <mxCell id="r-effective" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="构造 effectiveQuestion&lt;br&gt;澄清回复拼回 originalQuestion｜追问携带隐藏 productContext" vertex="1">
          <mxGeometry height="75" width="580" x="610" y="375" as="geometry" />
        </mxCell>
        <mxCell id="r-normalize" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="标准化关键词、短语、同义词、意图与型号&lt;br&gt;词/短语边界匹配；仅短型号允许一次相邻字符换位" vertex="1">
          <mxGeometry height="45" width="580" x="610" y="470" as="geometry" />
        </mxCell>
        <mxCell id="r-lane-b" parent="r1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="B. Tenant-scoped Hybrid Retrieval" vertex="1">
          <mxGeometry height="760" width="1680" x="60" y="560" as="geometry" />
        </mxCell>
        <mxCell id="r-filter" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;fontStyle=1;" value="Prisma ACTIVE Evidence Filter&lt;br&gt;tenantId + KnowledgeDocument READY + KnowledgeChunk READY" vertex="1">
          <mxGeometry height="75" width="520" x="640" y="620" as="geometry" />
        </mxCell>
        <mxCell id="r-keyword" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Keyword 路径&lt;br&gt;Pool ≤ 400&lt;br&gt;内容/标题 contains + 词法评分&lt;br&gt;Keyword Top-20" vertex="1">
          <mxGeometry height="110" width="370" x="260" y="750" as="geometry" />
        </mxCell>
        <mxCell id="r-semantic" parent="r1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="Semantic 路径&lt;br&gt;Pool ≤ 400&lt;br&gt;本地稀疏向量 + cosine&lt;br&gt;Vector Top-20" vertex="1">
          <mxGeometry height="110" width="370" x="1170" y="750" as="geometry" />
        </mxCell>
        <mxCell id="r-local-note" parent="r1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="当前无外部 Vector DB&lt;br&gt;无神经 embedding" vertex="1">
