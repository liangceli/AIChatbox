<mxfile host="app.diagrams.net" agent="Codex" compressed="false" pages="3">
  <diagram id="main-flow-clean" name="01 主流程总览">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1400" pageHeight="2100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Haneco AI Pilot｜用户问题到答案展示（主流程）" vertex="1">
          <mxGeometry height="50" width="1000" x="200" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p1-lane-a" parent="1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="A. Widget 与安全边界" vertex="1">
          <mxGeometry height="390" width="1300" x="50" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p1-note" parent="p1-lane-a" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" value="阅读方式：中间为正常路径；右侧为就地结束的分支。无跨页回线，RAG 细节见第 2 页。" vertex="1">
          <mxGeometry height="80" width="300" x="980" y="55" as="geometry" />
        </mxCell>
        <mxCell id="p1-user" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=15;fontStyle=1;" value="1　用户输入问题" vertex="1">
          <mxGeometry height="65" width="460" x="470" y="155" as="geometry" />
        </mxCell>
        <mxCell id="p1-widget" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="2　Customer Widget&lt;br&gt;清空输入框｜生成 UUID clientMessageId｜复用或刷新 HMAC Widget Session" vertex="1">
          <mxGeometry height="80" width="540" x="430" y="255" as="geometry" />
        </mxCell>
        <mxCell id="p1-request" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#000000;fontSize=13;" value="3　POST /v1/chat/messages&lt;br&gt;IP 限流 → WidgetSessionGuard → ACTIVE Tenant → tenantSlug 一致性 → Tenant/Visitor 限流" vertex="1">
          <mxGeometry height="90" width="600" x="400" y="375" as="geometry" />
        </mxCell>
        <mxCell id="p1-security-stop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="校验或限流失败&lt;br&gt;401 / 429，结束本次请求" vertex="1">
          <mxGeometry height="70" width="240" x="1060" y="385" as="geometry" />
        </mxCell>
        <mxCell id="p1-lane-b" parent="1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="B. 用户消息持久化与幂等" vertex="1">
          <mxGeometry height="430" width="1300" x="50" y="520" as="geometry" />
        </mxCell>
        <mxCell id="p1-idempotent" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=13;" value="4　tenantId + clientMessageId 已处理？" vertex="1">
          <mxGeometry height="105" width="380" x="510" y="575" as="geometry" />
        </mxCell>
        <mxCell id="p1-duplicate-stop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" value="是：返回原 Conversation + Messages&lt;br&gt;不重复写入，不重复生成答案" vertex="1">
          <mxGeometry height="75" width="290" x="1010" y="590" as="geometry" />
        </mxCell>
        <mxCell id="p1-save-user" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="5　PostgreSQL 事务&lt;br&gt;Upsert Customer → 校验/创建 Conversation → 写 CUSTOMER Message" vertex="1">
          <mxGeometry height="80" width="560" x="420" y="720" as="geometry" />
        </mxCell>
        <mxCell id="p1-human-before" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;" value="6　当前为 PENDING_HUMAN / ASSIGNED？" vertex="1">
          <mxGeometry height="105" width="400" x="500" y="830" as="geometry" />
        </mxCell>
        <mxCell id="p1-human-stop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="是：用户消息已保存&lt;br&gt;assistantMessage = null&lt;br&gt;AI 继续暂停" vertex="1">
          <mxGeometry height="75" width="280" x="1020" y="845" as="geometry" />
        </mxCell>
        <mxCell id="p1-lane-c" parent="1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="C. 上下文、检索与答案候选" vertex="1">
          <mxGeometry height="390" width="1300" x="50" y="980" as="geometry" />
        </mxCell>
        <mxCell id="p1-context" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" value="7　加载对话上下文 + 路由策略（更新）&lt;br&gt;AgentConfig.metadata.conversationRouting + ConversationState + ProductCatalog/legacy fallback + 最近 8 轮" vertex="1">
          <mxGeometry height="80" width="580" x="410" y="1035" as="geometry" />
        </mxCell>
        <mxCell id="p1-engine" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" value="8　对话意图路由（更新）+ Hybrid RAG + Provider Grounding&lt;br&gt;先分类状态型回复 / 社交对话 / 新问题与追问；输出：直接会话回复 / 澄清问题 / 安全缺口 / 有依据答案" vertex="1">
          <mxGeometry height="90" width="640" x="380" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="p1-clarify-decision" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;" value="9　输出是产品澄清问题？" vertex="1">
          <mxGeometry height="95" width="340" x="530" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="p1-conversation-note" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="更新：问候 / 社交 / 感谢 / 确认&lt;br&gt;直接由 AssistantReplyService 回复&lt;br&gt;跳过 RAG，不触发 knowledge miss；若存在 pendingClarification 则保留" vertex="1">
          <mxGeometry height="90" width="280" x="1040" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="p1-clarify-stop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="是：写 Assistant 澄清消息&lt;br&gt;保存 pendingClarification + TTL&lt;br&gt;状态 AWAITING_CUSTOMER，返回 Widget" vertex="1">
          <mxGeometry height="80" width="300" x="1000" y="1268" as="geometry" />
        </mxCell>
        <mxCell id="p1-lane-d" parent="1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="D. Provider 后并发保护与答案落库" vertex="1">
          <mxGeometry height="400" width="1300" x="50" y="1400" as="geometry" />
        </mxCell>
        <mxCell id="p1-recheck" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;" value="10　Provider 返回后重新读取 Conversation&lt;br&gt;期间是否已进入人工模式？" vertex="1">
          <mxGeometry height="115" width="400" x="500" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="p1-discard-stop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="是：丢弃 AI 生成结果&lt;br&gt;不写 Assistant Message&lt;br&gt;保持人工模式并返回最新会话" vertex="1">
          <mxGeometry height="85" width="290" x="1010" y="1475" as="geometry" />
        </mxCell>
        <mxCell id="p1-save-answer" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;" value="11　PostgreSQL 事务&lt;br&gt;写 Assistant Message + citations + retrieval/provider diagnostics" vertex="1">
          <mxGeometry height="80" width="560" x="420" y="1615" as="geometry" />
        </mxCell>
        <mxCell id="p1-state" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#000000;fontSize=12;" value="12　更新 ConversationState / ProductCatalog&lt;br&gt;同步或清空 legacy metadata.rag｜Conversation = AWAITING_CUSTOMER" vertex="1">
          <mxGeometry height="70" width="580" x="410" y="1715" as="geometry" />
        </mxCell>
        <mxCell id="p1-lane-e" parent="1" style="swimlane;horizontal=1;startSize=36;html=1;fillColor=#f5f5f5;strokeColor=#777777;fontSize=15;fontStyle=1;" value="E. 返回与持续同步" vertex="1">
          <mxGeometry height="230" width="1300" x="50" y="1830" as="geometry" />
        </mxCell>
        <mxCell id="p1-render" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" value="13　返回完整 Conversation + Messages&lt;br&gt;Widget 渲染答案与 citations，并保存 conversationId" vertex="1">
          <mxGeometry height="75" width="600" x="400" y="1885" as="geometry" />
        </mxCell>
        <mxCell id="p1-sse" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" value="14　EventSource 每 2 秒拉取 tenant + visitor scoped snapshot&lt;br&gt;刷新后使用本地 Widget Session + conversationId 恢复历史" vertex="1">
          <mxGeometry height="65" width="600" x="400" y="1980" as="geometry" />
        </mxCell>
        <mxCell id="p1-e1" edge="1" parent="1" source="p1-user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;" target="p1-widget">
